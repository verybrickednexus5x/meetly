# Env files
# NOTE: this is a Lovable-connected project. Lovable requires .env to be
# committed to the repo so build-time VITE_* values are available when
# generating previews and published builds — gitignoring it breaks the
# build. Only truly server-only secrets (no VITE_ prefix, e.g. a service
# role key) belong in Lovable's Cloud -> Secrets instead, never in .env.
.env.local
.env.*.local

# Auto-generated by @tanstack/router-plugin on every dev/build run
src/routeTree.gen.ts

# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

node_modules
dist
dist-ssr
.output
.vinxi
.tanstack/**
.nitro
*.local

# This project uses bun (see bunfig.toml + bun.lock) — don't commit npm's lockfile
package-lock.json

# Wrangler / Cloudflare
.wrangler/
.dev.vars

# Editor directories and files
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
